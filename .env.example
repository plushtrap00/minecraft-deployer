# ══════════════════════════════════════════════════════════════════════════
# Minecraft Server Deployer — variables de entorno
#
# Este archivo documenta TODAS las variables que la app realmente lee
# (config.py, routes/auth.py, services/users.py). No hace falta rellenarlo
# a mano en un uso normal: install.sh (nativo) y setup.py (Docker) generan
# el .env real por ti con las credenciales y el secreto ya calculados.
#
# Editable también desde el panel de administración web (⚙️ Configuración,
# solo rol admin) una vez la app está arrancada, sin tocar este archivo a mano.
#
# Los números de ajuste (timeouts, límites, tamaños de caché) NO viven acá:
# están en .APP_CONSTANTS (JSON, en la raíz del repo), que sí se versiona en
# git porque no tiene nada sensible — ver app_constants.py.
# ══════════════════════════════════════════════════════════════════════════

# ── Requeridas para que la app arranque ─────────────────────────────────────

# Usuario y hash bcrypt de la contraseña del admin. Genera el hash con:
# python3 set_password.py (interactivo) o install.sh/setup.py en la instalación.
APP_USERNAME=admin
APP_PASSWORD_HASH=

# Secret para firmar los JWT. OBLIGATORIO generar uno propio antes de producción —
# nunca uses un valor de ejemplo commiteado en un repo: cualquiera que lo lea puede
# forjar tokens válidos (incluido rol admin). Se genera solo al correr
# `python3 set_password.py` o `install.sh` si esta línea está vacía; para generarlo
# a mano: python3 -c "import secrets; print(secrets.token_hex(32))"
# No lo cambies una vez en producción salvo que quieras invalidar todas las sesiones.
JWT_SECRET=

# ── Opcionales (la app funciona sin ellas, con el comportamiento indicado) ──

# Puerto de la interfaz web. Por defecto 8000 si se deja vacío.
WEB_PORT=8000

# Carpeta donde se guardan los modpacks/servidores. Por defecto
# ~/servers-minecraft si se deja vacío (o /servers dentro del contenedor Docker).
SERVERS_PATH=

# Dominio público con el que los jugadores se conectan al servidor Minecraft
# (solo informativo, se muestra en la interfaz). Vacío = se muestra la IP.
MC_DOMAIN=

# Habilita la búsqueda de mods en CurseForge (Modrinth funciona sin esto).
# Se consigue gratis en https://console.curseforge.com/#/api-keys
CURSEFORGE_API_KEY=

# Auto-actualización: si es "true", la app comprueba cada AUTO_UPDATE_INTERVAL_
# SECONDS si origin/main tiene commits nuevos y, si no hay ningún servidor de
# Minecraft corriendo ni ninguna subida/instalación en curso, hace git pull y
# se reinicia sola (funciona igual en systemd nativo que en Docker). Por
# defecto "false": es un cambio de comportamiento grande como para activarlo
# sin pedirlo a propósito.
AUTO_UPDATE_ENABLED=false
AUTO_UPDATE_INTERVAL_SECONDS=300

# Compatibilidad hacia atrás: si APP_PASSWORD_HASH no está seteada, se usa
# esta como fallback. No hace falta tocarla en instalaciones nuevas.
PABLO_PASSWORD_HASH=
